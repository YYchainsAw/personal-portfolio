# This is an inventory, not a production secret file. Install the real values as:
#   /etc/portfolio/postgres.env   root:root             0600
#   /etc/portfolio/portfolio.env  root:root             0600
#   /etc/portfolio/release.env    root:portfolio-deploy 0640
# Generate database passwords with `openssl rand -base64 32` and application
# secrets with `openssl rand -base64 48`. Never print a generated value after
# writing its protected destination.

# /etc/portfolio/release.env: immutable release topology only.
# POSTGRES_IMAGE must be a reviewed postgres:17...@sha256:<64 lowercase hex> ref.
POSTGRES_IMAGE=
PORTFOLIO_IMAGE=
PORTFOLIO_RELEASE_ID=

# /etc/portfolio/postgres.env: PostgreSQL bootstrap and isolated login roles.
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio_owner
POSTGRES_PASSWORD=
POSTGRES_OWNER=portfolio_owner
POSTGRES_OWNER_PASSWORD=
POSTGRES_DEV_PORT=5432
PORTFOLIO_DB_MIGRATOR_USER=portfolio_migrator
PORTFOLIO_DB_MIGRATOR_PASSWORD=
PORTFOLIO_DB_RUNTIME_USER=portfolio_runtime
PORTFOLIO_DB_RUNTIME_PASSWORD=
# Copy the four PORTFOLIO_DB_* role assignments above into portfolio.env too;
# the API needs the runtime login and Flyway needs the migrator login.

# /etc/portfolio/portfolio.env: database connectivity inside the Compose network.
PORTFOLIO_DB_URL=jdbc:postgresql://postgres:5432/portfolio?currentSchema=portfolio
PORTFOLIO_DB_MIGRATOR_URL=jdbc:postgresql://postgres:5432/portfolio?currentSchema=portfolio
PORTFOLIO_BIND_ADDRESS=0.0.0.0
PORTFOLIO_PORT=8080

# Authentication and same-origin browser boundary.
PORTFOLIO_SESSION_COOKIE_SECURE=true
PORTFOLIO_ALLOW_DEVELOPMENT_CORS=false
PORTFOLIO_ADMIN_DEV_ORIGIN=http://localhost:5174
PORTFOLIO_TOTP_ACTIVE_KEY_VERSION=1
PORTFOLIO_TOTP_KEY_RING=

# Publishing and public rendering.
PORTFOLIO_PREVIEW_HMAC_KEY=
PORTFOLIO_PUBLIC_BASE_URL=https://yychainsaw.xyz
PORTFOLIO_VITE_MANIFEST=classpath:/public-assets/.vite/manifest.json

# Runtime Tencent COS location and credential. The session token is optional.
PORTFOLIO_STORAGE_DEFAULT_PROVIDER=TENCENT_COS
# Optional extra adapter gate. TENCENT_COS as the default already requires COS;
# set this true only for mixed mode with LOCAL as the default writer.
PORTFOLIO_COS_ENABLED=false
COS_REGION=
COS_BUCKET=
COS_SECRET_ID=
COS_SECRET_KEY=
COS_SESSION_TOKEN=

# Durable Local fallback and bounded per-node COS upload scratch.
PORTFOLIO_LOCAL_STORAGE=/var/lib/portfolio/media
PORTFOLIO_COS_STAGING_ROOT=/tmp/portfolio-cos-staging
# Protected opaque value stored separately and written owner-only/no-follow to
# /var/lib/portfolio/media/.portfolio-volume-id before the API is started.
PORTFOLIO_LOCAL_VOLUME_ID=

# Staging cleanup requires both the worker gate and its own cleanup gate.
PORTFOLIO_JOBS_WORKER_ENABLED=true
PORTFOLIO_STAGING_CLEANUP_ENABLED=true
# Keep destructive archive cleanup off in the template; production preflight
# enables it only after the complete reference and volume-identity gates pass.
PORTFOLIO_MEDIA_CLEANUP_ENABLED=false
PORTFOLIO_JOBS_RETENTION_ENABLED=false
PORTFOLIO_JOBS_RETENTION_BATCH_SIZE=500
PORTFOLIO_JOBS_RETENTION_MAX_BATCHES=10
PORTFOLIO_MEDIA_INGEST_TRANSACTION_TIMEOUT=PT30S
PORTFOLIO_LOCAL_PUBLICATION_MAX_CONCURRENCY=2
PORTFOLIO_LOCAL_PUBLICATION_CONNECTION_HEADROOM=2
PORTFOLIO_LOCAL_PUBLICATION_ACQUIRE_TIMEOUT=PT10S
PORTFOLIO_LOCAL_PUBLICATION_OPERATION_TIMEOUT=PT2M

# Contact notifications are durably queued even while SMTP delivery is disabled.
PORTFOLIO_EMAIL_ENABLED=false
PORTFOLIO_EMAIL_FROM=
PORTFOLIO_OWNER_EMAIL=
PORTFOLIO_MAIL_ID_DOMAIN=yychainsaw.xyz
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Canonical base64 secrets containing at least 32 random bytes. Never commit values.
PORTFOLIO_CONTACT_DEDUPE_SECRET=
PORTFOLIO_ANALYTICS_HMAC_SECRET=
PORTFOLIO_ANALYTICS_MAINTENANCE_SCHEDULING_ENABLED=true

# Local recovery CLI. The current implementation derives the endpoint from the
# JDBC URL; the host/port names remain listed for plan-01 compatibility.
PORTFOLIO_RECOVERY_DIRECTORY=/var/lib/portfolio/recovery
PORTFOLIO_PG_DUMP_BIN=pg_dump
PORTFOLIO_PG_DUMP_TIMEOUT=PT2M
PORTFOLIO_RECOVERY_DB_HOST=postgres
PORTFOLIO_RECOVERY_DB_PORT=5432
