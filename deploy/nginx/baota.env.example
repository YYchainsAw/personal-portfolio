# Documentation values only. Install reviewed values as
# /etc/portfolio/nginx.env, owner root:portfolio-deploy, mode 0640.
TENCENT_REGION=ap-guangzhou
SERVER_JURISDICTION=MAINLAND_CN
ICP_APPROVED=false
ICP_NUMBER=
PUBLIC_DOMAIN_ENABLED=false
PUBLIC_HOSTS=yychainsaw.xyz,www.yychainsaw.xyz
EXPECTED_PUBLIC_IPV4=203.0.113.10
EXPECTED_PUBLIC_IPV6=NONE

NGINX_BIN=/www/server/nginx/sbin/nginx
NGINX_PREFIX=/www/server/nginx/
NGINX_CONF=/www/server/nginx/conf/nginx.conf
NGINX_PID=/www/server/nginx/logs/nginx.pid
TLS_CERTIFICATE=/www/server/panel/vhost/cert/yychainsaw.xyz/fullchain.pem
TLS_CERTIFICATE_KEY=/www/server/panel/vhost/cert/yychainsaw.xyz/privkey.pem
API_LOOPBACK=127.0.0.1:18080

# A single HTTPS origin used for image/video delivery. Comma-separate frame
# origins; paths, wildcards, quotes, semicolons, whitespace, and HTTP fail.
MEDIA_ORIGIN=https://media.yychainsaw.xyz
VIDEO_FRAME_ORIGINS=https://player.bilibili.com,https://www.youtube-nocookie.com

# Preflight-protected release/runtime paths.
PORTFOLIO_ROOT=/opt/portfolio
PORTFOLIO_POSTGRES_ENV=/etc/portfolio/postgres.env
PORTFOLIO_APP_ENV=/etc/portfolio/portfolio.env
PORTFOLIO_RELEASE_ENV=/etc/portfolio/release.env
PORTFOLIO_NGINX_ENV=/etc/portfolio/nginx.env
PORTFOLIO_COMPOSE_FILE=/opt/portfolio/ops/deploy/docker-compose.prod.yml
# Leave blank to resolve the running portfolio-api container through this
# exact Compose project; never guess Compose's generated container name.
PORTFOLIO_CONTAINER_NAME=
PORTFOLIO_RELEASE_ID=
PORTFOLIO_MIN_FREE_KIB=2097152
PORTFOLIO_LOCAL_VOLUME_NAME=portfolio-local-media
PORTFOLIO_LOCAL_HOST_ROOT=/var/lib/docker/volumes/portfolio-local-media/_data
PORTFOLIO_LOCAL_MIN_FREE_KIB=1048576
PORTFOLIO_LOCAL_VOLUME_ID=
PORTFOLIO_LOCAL_STAGING_SCAN_LIMIT=100000
PORTFOLIO_JOBS_WORKER_ENABLED=true
PORTFOLIO_STAGING_CLEANUP_ENABLED=true
PORTFOLIO_MEDIA_CLEANUP_ENABLED=true

# Preflight times its own no-follow, same-filesystem Local staging scan and
# requires that sanitized duration to remain below this lease fraction.
PORTFOLIO_JOB_LEASE_MILLIS=120000
PORTFOLIO_CLEANUP_SCAN_MAX_LEASE_PERCENT=50

# Every configured adapter and every historical media_asset location must be
# represented. COS locations are comma-separated bucket@region pairs.
PORTFOLIO_STORAGE_ADAPTERS=LOCAL,TENCENT_COS
PORTFOLIO_STORAGE_DEFAULT_PROVIDER=TENCENT_COS
PORTFOLIO_COS_LOCATIONS=
COS_REGION=
COS_BUCKET=
COS_SECRET_ID=
COS_SECRET_KEY=
COS_RUNTIME_LIFECYCLE_MANAGEMENT_DISABLED=true

# Separate, short-lived lifecycle-read credential. It must not be the runtime
# media credential and may be unset again immediately after preflight.
COS_LIFECYCLE_READ_SECRET_ID=
COS_LIFECYCLE_READ_SECRET_KEY=
COS_LIFECYCLE_READ_SECURITY_TOKEN=
PORTFOLIO_COS_LIFECYCLE_VERIFY_COMMAND=/opt/portfolio/ops/deploy/scripts/verify-cos-staging-lifecycle.sh
