# Generated by deploy/scripts/render-nginx.sh. Do not edit the installed copy.
# ICP record: @@ICP_NUMBER@@

server {
    listen 80;
    listen [::]:80;
    server_name @@PUBLIC_HOSTS@@;
    return 308 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name @@PUBLIC_HOSTS@@;

    ssl_certificate @@TLS_CERTIFICATE@@;
    ssl_certificate_key @@TLS_CERTIFICATE_KEY@@;

    include @@NGINX_INCLUDE_DIRECTORY@@/portfolio-security-headers.conf;

    location ^~ /assets/ {
        alias /opt/portfolio/assets/;
        try_files $uri =404;
        include @@NGINX_INCLUDE_DIRECTORY@@/portfolio-security-headers.conf;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
    }

    location = /admin { return 308 /admin/; }

    location ^~ /admin/assets/ {
        alias /opt/portfolio/current-admin/assets/;
        try_files $uri =404;
        include @@NGINX_INCLUDE_DIRECTORY@@/portfolio-security-headers.conf;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
    }

    location /admin/ {
        alias /opt/portfolio/current-admin/;
        try_files $uri $uri/ /admin/index.html;
        include @@NGINX_INCLUDE_DIRECTORY@@/portfolio-security-headers.conf;
        add_header Cache-Control "no-store" always;
    }

    location = /actuator { return 404; }
    location ^~ /actuator/ { return 404; }

    location = /api/admin/auth/login {
        limit_req zone=portfolio_login burst=3 nodelay;
        proxy_pass http://@@API_LOOPBACK@@;
        include @@NGINX_INCLUDE_DIRECTORY@@/portfolio-proxy.conf;
    }

    location = /api/public/contact {
        limit_req zone=portfolio_contact burst=5 nodelay;
        proxy_pass http://@@API_LOOPBACK@@;
        include @@NGINX_INCLUDE_DIRECTORY@@/portfolio-proxy.conf;
    }

    location = /api/public/events {
        limit_req zone=portfolio_events burst=20 nodelay;
        proxy_pass http://@@API_LOOPBACK@@;
        include @@NGINX_INCLUDE_DIRECTORY@@/portfolio-proxy.conf;
    }

    location = /api {
        proxy_pass http://@@API_LOOPBACK@@;
        include @@NGINX_INCLUDE_DIRECTORY@@/portfolio-proxy.conf;
    }

    location ^~ /api/ {
        proxy_pass http://@@API_LOOPBACK@@;
        include @@NGINX_INCLUDE_DIRECTORY@@/portfolio-proxy.conf;
    }

    # Public HTML, project, privacy, sitemap, and robots routes are rendered by
    # Spring. There is deliberately no public SPA fallback in BaoTa Nginx.
    location / {
        proxy_pass http://@@API_LOOPBACK@@;
        include @@NGINX_INCLUDE_DIRECTORY@@/portfolio-proxy.conf;
    }
}
