# Install the real file as /etc/portfolio/backup.env, root:root, mode 0600.
# Values below are syntax-only placeholders and are not usable credentials.

BACKUP_AGE_RECIPIENT=
BACKUP_REMOTE=portfolio-backup:yychainsaw-portfolio-backup
BACKUP_PREFIX=production
BACKUP_DESTINATION_ACCOUNT_ID=
BACKUP_DESTINATION_BUCKET=yychainsaw-portfolio-backup
BACKUP_UPLOAD_RCLONE_CONFIG=/etc/portfolio/rclone-backup-uploader.conf
BACKUP_VERIFY_RCLONE_CONFIG=/etc/portfolio/rclone-backup-verifier.conf
BACKUP_PRUNE_RCLONE_CONFIG=/etc/portfolio/rclone-backup-pruner.conf
BACKUP_UPLOAD_PRINCIPAL_ID=
BACKUP_VERIFY_PRINCIPAL_ID=
BACKUP_PRUNE_PRINCIPAL_ID=

MEDIA_SOURCE_RCLONE_REMOTE=portfolio-media:yychainsaw-portfolio-media
MEDIA_SOURCE_RCLONE_CONFIG=/etc/portfolio/rclone-media-reader.conf
MEDIA_SOURCE_ACCOUNT_ID=
MEDIA_SOURCE_BUCKET=yychainsaw-portfolio-media
MEDIA_SOURCE_REGION=ap-guangzhou
MEDIA_SOURCE_PRINCIPAL_ID=

# Must match deploy/nginx/baota.env and the fixed external Compose volume.
PORTFOLIO_LOCAL_VOLUME_NAME=portfolio-local-media
PORTFOLIO_LOCAL_HOST_ROOT=/var/lib/docker/volumes/portfolio-local-media/_data
PORTFOLIO_LOCAL_VOLUME_ID=

BACKUP_EMAIL_TO=
BACKUP_EMAIL_FROM=
BACKUP_MSMTP_CONFIG=/etc/portfolio/msmtp-backup.conf
BACKUP_TIMEZONE=Asia/Hong_Kong
# Leave this at the operating-system tzdata root in production.
BACKUP_ZONEINFO_ROOT=/usr/share/zoneinfo
BACKUP_WEEKLY_DAY=1
BACKUP_RETENTION_SAFETY_DAYS=14
BACKUP_STAGING_ROOT=/var/backups/portfolio/staging
BACKUP_PRUNE_STAGING_ROOT=/var/backups/portfolio/prune

# This root-owned adapter must prove the destination account/bucket, versioning,
# Object Lock/WORM retention, exact object version IDs, principal role, and the
# reviewed non-root prefix before it returns SAFE or performs delete-reviewed.
# Pruning fails closed without this provider-specific adapter.
BACKUP_PRUNE_GUARD_COMMAND=/usr/local/sbin/portfolio-backup-prune-guard

# The following phrase is intentionally blank in normal operation. It is only
# set interactively during a documented disaster reset after independent review.
BACKUP_DISASTER_RESET_CONFIRMATION=
