{
  "name": "portfolio-admin-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.18.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && vite build",
    "sbom:prod": "cyclonedx-npm --package-lock-only --omit dev --spec-version 1.6 --output-reproducible --output-format JSON --validate",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "axios": "1.18.1",
    "qrcode": "1.5.4",
    "vue": "3.5.31",
    "vue-router": "4.6.4"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "6.0.0",
    "@playwright/test": "1.58.2",
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "22.18.0",
    "@types/qrcode": "1.5.6",
    "@vitejs/plugin-vue": "6.0.3",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.9.1",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "ajv-formats-draft2019": "1.6.1",
    "jsdom": "28.0.0",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  }
}
